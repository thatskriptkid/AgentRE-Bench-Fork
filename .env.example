# AgentRE-Bench API Keys
# Copy this file to .env and fill in the keys for the providers you want to use.
#
#   cp .env.example .env
#
# Only the key for your chosen --provider is required.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
DEEPSEEK_API_KEY=sk-...
# Alibaba Qwen (DashScope). Key must match region (Beijing/Singapore/US).
# Coding Plan (sk-sp-*): set DASHSCOPE_BASE_URL from Model Studio → Coding Plan → Plan Exclusive Base URL
#   Singapore: https://coding-intl.dashscope.aliyuncs.com/v1
#   China:     https://coding.dashscope.aliyuncs.com/v1
# Optional for non-Coding: DASHSCOPE_BASE_URL (e.g. https://dashscope-intl.aliyuncs.com/compatible-mode/v1)
DASHSCOPE_API_KEY=sk-...
